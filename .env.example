APP_ENV=development
APP_SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ysdevidx
APP_WEB_URL=http://localhost:3000
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_NAME=ysdi_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_TTL_DAYS=30
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/auth/github/callback
EMAIL_FROM=no-reply@ysdevidx.com
EMAIL_PROVIDER_API_KEY=your-email-provider-api-key
VERIFICATION_CODE_TTL_MINUTES=10
VERIFICATION_MAX_ATTEMPTS=5
VERIFICATION_REQUEST_COOLDOWN_SECONDS=60
PROFILE_UPDATE_MAX_PER_DAY=5
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
